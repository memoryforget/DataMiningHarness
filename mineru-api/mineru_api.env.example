# Copy this file to mineru_api.env before use.
# Paths may be relative to the directory containing this file.

CONDA_ENV_NAME=mineru
ACTIVATE_BASE_SH=../activate_my_base.sh

HOST=0.0.0.0
PORT=18000
CUDA_VISIBLE_DEVICES=0
VLLM_USE_V1=1
MINERU_MODEL_SOURCE=local
ENABLE_VLM_PRELOAD=true

MODEL_TYPE=vlm
MODEL_DIR=../../models/MinerU2.5-2509-1.2B

RUNTIME_ROOT=../tmp/mineru_api_home
TOOLS_CONFIG_NAME=mineru_tools.json
LOG_FILE=../tmp/mineru_api_18000.log
PID_FILE=../tmp/mineru_api_18000.pid
